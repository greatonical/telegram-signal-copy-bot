# Telegram API Credentials
# Get these from https://my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_here

# Phone number (with country code)
PHONE_NUMBER=+1234567890

# Feature Flags (set to false to disable without removing config)
ENABLE_FORWARDING=true
ENABLE_AUTO_TRADING=true

# IQ Option Credentials
IQ_OPTION_EMAIL=your_email@example.com
IQ_OPTION_PASSWORD=your_password

# Auto-Trading Settings
TRADE_AMOUNT=1.0
MAX_DAILY_LOSS=10.0
AUTO_TRADE_SOURCES=-1003108945324
USE_PRACTICE_ACCOUNT=true
# Max seconds to wait for a signal's scheduled minute (default 120 = 2 minutes)
SIGNAL_MAX_WAIT_SECONDS=120
